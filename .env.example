# AWS RDS PostgreSQL connection (provided by the instructor)
RDS_HOST=your-instance.xxxxxxxxxxxx.eu-west-3.rds.amazonaws.com
RDS_PORT=5432
RDS_DATABASE=kickz_empire
RDS_USER=your_username
RDS_PASSWORD=your_password

# Schema names (replace 0 with your group number)
BRONZE_SCHEMA=bronze_group0
SILVER_SCHEMA=silver_group0
GOLD_SCHEMA=gold_group0

# AWS S3 (read-only — raw data)
S3_BUCKET_NAME=kickz-empire-data
S3_PREFIX=raw
AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
